# Production Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git - it's already in .gitignore

# Admin login identity (password is managed by Firebase Auth, not client env)
REACT_APP_ADMIN_EMAIL=admin@example.com
# Required admin user ID for login screen (legacy user ID)
REACT_APP_ADMIN_USERNAME=admin
# Optional second admin login identity
REACT_APP_ADMIN_EMAIL_2=second-admin@example.com
# Optional second admin user ID
REACT_APP_ADMIN_USERNAME_2=admin2

# Contact Information
REACT_APP_WHATSAPP_NUMBER=917840930140

# Social Media Links
REACT_APP_FACEBOOK_URL=https://facebook.com/romanceretreat
REACT_APP_INSTAGRAM_URL=https://instagram.com/romanceretreat
REACT_APP_TWITTER_URL=https://x.com/romanceretreat

# Instructions:
# 1. Copy this file to .env.local
# 2. Set REACT_APP_ADMIN_EMAIL to your Firebase Auth admin user email
# 3. Set REACT_APP_ADMIN_USERNAME to your old admin user ID
# 4. Optionally set REACT_APP_ADMIN_EMAIL_2 and REACT_APP_ADMIN_USERNAME_2
# 5. Update social media URLs to your actual accounts
# 6. Never commit .env.local to version control